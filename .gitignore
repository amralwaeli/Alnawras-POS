node_modules/
.env
.DS_Store

# Build outputs — never commit these, CI builds them automatically
dist/
docs/

# Editor
.vscode/
*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# ── Android (Capacitor) ──────────────────────────────────────────────────────
# The android/ folder is generated by `npx cap add android` and should NOT
# be committed. It is large, machine-specific, and can always be regenerated.
android/

# If you ever decide to commit android/ (e.g. for CI), at minimum exclude:
# android/.gradle/
# android/app/build/
# android/build/
# android/**/*.apk
# android/**/*.aab
# android/local.properties

# ── iOS (Capacitor) ─────────────────────────────────────────────────────────
ios/

# ── Capacitor plugins cache ──────────────────────────────────────────────────
.capacitor/
